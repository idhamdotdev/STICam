<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Pure OLED black theme used as the window background before Compose renders.
         Theme.AppCompat.NoActionBar is always available (comes with appcompat).
         Compose handles all actual UI — this theme only controls the window chrome. -->
    <style name="Theme.Sticam" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
    </style>
</resources>
