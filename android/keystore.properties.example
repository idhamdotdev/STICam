# Release signing credentials — copy to keystore.properties and fill in.
# NEVER commit keystore.properties or the keystore file itself.
#
# Generate a keystore once with:
#   keytool -genkeypair -v -keystore keystore/sticam-release.jks -alias sticam \
#     -keyalg RSA -keysize 4096 -validity 10950
#
# storeFile is resolved relative to the android/ directory.
storeFile=keystore/sticam-release.jks
storePassword=CHANGE_ME
keyAlias=sticam
keyPassword=CHANGE_ME
